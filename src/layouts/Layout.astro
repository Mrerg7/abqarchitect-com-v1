---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'abqarchitect.com — Premium exact-match domain for Albuquerque architecture. The definitive digital brand for an architect, firm, or developer in ABQ.', ogImage } = Astro.props;
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalURL = new URL(pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Site Verification -->
    <meta name="google-site-verification" content="lWQEbHxYog8lUq4hDj-yNCDcOjrnp1GZD9uNu7JjMoI" />
    <meta name="google-site-verification" content="5fpja6t4dYEOuJQS0noyZTRQSWJI5fQOpDUtdhgBU04" />

    <!-- Preconnect to CDN -->
    <link rel="preconnect" href="https://imagedelivery.net" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Playfair+Display:wght@700&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <title>{title}</title>

    <slot name="head" />
  </head>
  <body class="bg-zinc-950 text-zinc-200 antialiased">
    <!-- Navigation -->
    <nav id="nav" class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800 bg-zinc-950/90 backdrop-blur-lg transition-all">
      <div class="max-w-screen-2xl mx-auto">
        <div class="px-6 lg:px-8 py-5 flex items-center justify-between">
          <div class="flex items-center gap-x-3">
            <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-br from-amber-500 to-orange-600">
              <i class="fa-solid fa-building text-white text-xl"></i>
            </div>
            <div>
              <span class="font-semibold tracking-tight text-xl lg:text-2xl">abqarchitect</span>
              <span class="text-amber-500 font-mono text-sm align-super">.com</span>
            </div>
          </div>

          <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
            <a href="#opportunity" class="hover:text-amber-400 transition-colors">The Opportunity</a>
            <a href="#value" class="hover:text-amber-400 transition-colors">Why This Domain</a>
            <a href="#market" class="hover:text-amber-400 transition-colors">Market Context</a>
            <a href="#acquire" class="hover:text-amber-400 transition-colors">Acquire</a>
          </div>

          <div class="flex items-center gap-x-3">
            <a href="#acquire"
               class="hidden sm:inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-2xl border border-zinc-700 hover:bg-zinc-900 transition-all active:scale-[0.985]">
              Inquire Now
            </a>
            <a href="#acquire"
               class="inline-flex items-center gap-x-2 px-6 py-2.5 bg-white text-zinc-950 font-semibold text-sm rounded-2xl hover:bg-amber-50 active:bg-white transition-all active:scale-[0.985]">
              <span>Secure This Asset</span>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-zinc-800">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8 py-12">
        <!-- Domain Acquisition CTA -->
        <div class="bg-gradient-to-b from-zinc-900 to-zinc-950 rounded-3xl p-8 md:p-10 mb-10 text-center border border-amber-500/10">
          <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 mb-6">
            <div class="w-2 h-2 bg-amber-400 rounded-full animate-pulse"></div>
            <span class="text-xs font-semibold tracking-[2px] text-amber-500">PREMIUM DOMAIN AVAILABLE FOR ACQUISITION</span>
          </div>

          <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 heading-serif">
            abqarchitect.com Is Available
          </h3>

          <p class="text-zinc-400 max-w-xl mx-auto mb-8 leading-relaxed text-base">
            A rare, exact-match geo-profession premium .com domain. The definitive digital identity for architecture in Albuquerque — available for acquisition by a serious buyer. One-time transfer, full ownership, escrow-protected.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="mailto:sales@desertrich.com?subject=Acquisition%20Inquiry%20-%20abqarchitect.com&body=Hello,%0D%0A%0D%0AI%20am%20interested%20in%20acquiring%20abqarchitect.com.%20Please%20provide%20details%20and%20next%20steps.%0D%0A%0D%0ABest%20regards,"
              class="inline-flex items-center justify-center gap-x-2 px-8 py-3.5 bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-600 hover:to-orange-700 active:brightness-105 text-white font-semibold rounded-2xl transition-all shadow-lg shadow-amber-500/20"
            >
              <span>Inquire: sales@desertrich.com</span>
              <i class="fa-solid fa-envelope text-sm"></i>
            </a>
            <button
              id="copyEmailBtn"
              class="inline-flex items-center justify-center gap-x-2 px-6 py-3.5 border border-zinc-700 hover:bg-white/5 text-zinc-300 font-medium rounded-2xl transition-all text-sm"
              onclick="copyEmail()"
            >
              <i class="fa-regular fa-copy"></i>
              <span>Copy Email</span>
            </button>
          </div>

          <p class="mt-4 text-xs text-zinc-500">
            Serious inquiries only. This domain is offered as a premium standalone digital asset.
          </p>
        </div>

        <!-- Bottom: Disclaimer + Legal -->
        <div class="border-t border-zinc-800 pt-8">
          <p class="text-xs text-zinc-500 mb-6 leading-relaxed max-w-4xl">
            <strong class="text-zinc-400">Disclaimer:</strong> This website is for demonstration and informational purposes only. It does not constitute an offer of services,
            a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
            technologies are based on publicly available information as of June 2026 and are subject to change.
          </p>

          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-y-3 text-xs text-zinc-500">
            <div>
              <p>&copy; 2026 abqarchitect.com &mdash; Curated with intention</p>
            </div>
            <div class="flex items-center gap-x-4">
              <span>One-time acquisition</span>
              <span class="hidden md:inline">&bull;</span>
              <span>Full ownership transfer</span>
              <span class="hidden md:inline">&bull;</span>
              <span>Premium .com</span>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <script>
      function copyEmail() {
        const email = 'sales@desertrich.com';
        navigator.clipboard.writeText(email).then(() => {
          const btn = document.getElementById('copyEmailBtn');
          if (btn) {
            const original = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-check text-emerald-400"></i><span class="text-emerald-400">Copied to clipboard!</span>';
            setTimeout(() => {
              btn.innerHTML = original;
            }, 2200);
          }
        }).catch(() => {
          window.location.href = 'mailto:' + email;
        });
      }

      // Sticky nav shadow on scroll
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('nav');
        if (nav) {
          if (window.scrollY > 80) {
            nav.classList.add('nav-scrolled');
          } else {
            nav.classList.remove('nav-scrolled');
          }
        }
      });

      console.log('%c[abqarchitect.com] Premium domain landing page ready.', 'color:#d97706');
    </script>
  </body>
</html>
